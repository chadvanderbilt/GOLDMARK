# GOLDMARK local secrets (DO NOT COMMIT)
#
# Copy this file to `configs/secrets.env` and fill in values:
#   cp configs/secrets.env.example configs/secrets.env
#
# Most GOLDMARK commands auto-load `configs/secrets.env` if present. You can also export in your shell:
#   set -a; source configs/secrets.env; set +a
#
# Notes:
# - NEVER commit `configs/secrets.env` or token files.
# - TCGA SVS downloads are typically open-access; GDC token is only needed for
#   controlled-access artifacts (e.g., some VCF/MAF).

# -----------------------------
# GDC (Genomic Data Commons)
# -----------------------------

# Path to your GDC token file (downloaded from the GDC portal).
# Used by `targets/tcga/gdc_download.sh` and `scripts/gdc_smoke_test_tcga.py`.
GDC_TOKEN_FILE=

# -----------------------------
# OncoKB
# -----------------------------

# OncoKB API token (required for `targets/variants/annotate_maf_oncokb_by_hgvsg.py`).
ONCOKB_TOKEN=

# -----------------------------
# Hugging Face (optional)
# -----------------------------

# If you use gated encoders / weights from Hugging Face Hub, set one of these:
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
